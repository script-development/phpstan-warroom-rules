{
    "name": "script-development/phpstan-warroom-rules",
    "description": "Canonical PHPStan rules enforcing war-room doctrine across script-development Laravel territories.",
    "license": "MIT",
    "type": "phpstan-extension",
    "keywords": [
        "phpstan",
        "phpstan-extension",
        "static-analysis",
        "laravel"
    ],
    "require": {
        "php": "^8.4",
        "phpstan/phpstan": "^2.0",
        "nikic/php-parser": "^5.0",
        "illuminate/database": "^11.0 || ^12.0 || ^13.0",
        "illuminate/contracts": "^11.0 || ^12.0 || ^13.0",
        "illuminate/cache": "^11.0 || ^12.0 || ^13.0",
        "illuminate/filesystem": "^11.0 || ^12.0 || ^13.0",
        "illuminate/log": "^11.0 || ^12.0 || ^13.0",
        "illuminate/mail": "^11.0 || ^12.0 || ^13.0",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "infection/infection": "^0.32.7",
        "laravel/pint": "^1.18",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "ScriptDevelopment\\PhpstanWarroomRules\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ScriptDevelopment\\PhpstanWarroomRules\\Tests\\": "tests/"
        },
        "classmap": [
            "tests/Fixtures/"
        ]
    },
    "extra": {
        "phpstan": {
            "includes": [
                "extension.neon"
            ]
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-clover=build/logs/clover.xml --coverage-text",
        "coverage:check": "@php bin/coverage-check.php build/logs/clover.xml 83",
        "mutation": "infection --threads=max --show-mutations",
        "mutation:ci": "infection --threads=4 --no-progress --logger-github --min-msi=75 --min-covered-msi=75",
        "phpstan": "phpstan analyse",
        "format": "pint",
        "format:check": "pint --test"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "infection/extension-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
